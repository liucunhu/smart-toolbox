# 应用配置
PROJECT_NAME=Smart-Toolbox
VERSION=1.0.0

# JWT 认证配置（⚠️ 生产环境必须修改）
# ⚠️ 重要：请使用以下命令生成强随机密钥：
# Python: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Linux: openssl rand -base64 32
SECRET_KEY=<请替换为生成的强随机密钥，至少32字符>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 数据库配置 (⚠️ 请替换为实际地址和密码)
# 格式: mysql+pymysql://用户名:密码@主机:端口/数据库名?charset=utf8mb4
DATABASE_URL=mysql+pymysql://username:<password>@remote-host:3306/smart_toolbox?charset=utf8mb4

# 数据库独立配置（用于脚本直接连接）
DB_HOST=localhost
DB_PORT=3306
DB_USER=toolbox_user
DB_PASSWORD=<your_db_password>
DB_NAME=smart_toolbox

# Redis 配置 (⚠️ 请替换为实际地址和密码)
# 格式: redis://:密码@主机:端口/数据库编号
REDIS_URL=redis://:<password>@remote-host:6379/0
CELERY_BROKER_URL=redis://:<password>@remote-host:6379/1
CELERY_RESULT_BACKEND=redis://:<password>@remote-host:6379/2

# Redis 独立配置（用于脚本直接连接）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<your_redis_password>

# AI 模型配置 (⚠️ 请替换为实际的API密钥)
LLM_PROVIDER=siliconflow
SILICONFLOW_API_KEY=<your_api_key_here>
# MODELSCOPE_API_KEY=<your_api_key_here>
# DEEPSEEK_API_KEY=<your_api_key_here>
# OPENAI_API_KEY=<your_api_key_here>

# 图像生成配置
DASHSCOPE_API_KEY=<your_dashscope_api_key_here>
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_IMAGE_MODEL=wanx2.1-t2i-turbo

# 网络搜索配置（用于获取实时素材进行二次原创）
# Bing Search API（推荐，需要订阅）
# BING_SEARCH_API_KEY=<your_bing_api_key>

# SerpAPI（付费但稳定，支持Google/Bing/Baidu）
# SERPAPI_API_KEY=<your_serpapi_key>

# 代理池配置 (可选)
PROXY_POOL_URL=http://your-proxy-service

# 头条账号配置（用于测试脚本）
TOUTIAO_USERNAME=<your_toutiao_username>
TOUTIAO_PASSWORD=<your_toutiao_password>

# CORS 配置（多个域名用逗号分隔）
# 开发环境
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# 生产环境示例（取消注释并修改为你的域名）
# BACKEND_CORS_ORIGINS=["https://yourdomain.com", "https://www.yourdomain.com"]
